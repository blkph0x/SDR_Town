*.pyc
*~
Thumbs.db
.DS_Store

# External / submodules (we commit the .gitmodules pointer + specific tracked files; full content is large so .gitignores help for build artifacts inside)
# Do NOT ignore the submodule directories themselves here - we want the gitlink
# external/liquid-dsp/   <--- commented so we can add submodule
# external/mbelib/

# Generated docs or reports (keep source only)
docs/generated/

# User data / runtime (never commit)
*.wav
*.png
*.json
!vcpkg.json
!CMakePresets.json
!resources/*.json
appdata/
recordings/
logs/

# Local release artifacts are uploaded to GitHub releases, not committed.
