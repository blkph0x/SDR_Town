{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows (vcpkg + Qt)",
      "description": "Configure for Windows with vcpkg and user-provided Qt6",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
          "type": "FILEPATH"
        },
        "CMAKE_PREFIX_PATH": {
          "value": "C:/Qt/6.7.0/msvc2022_64;C:/Qt/6.6.0/msvc2022_64;C:/Qt/6.5.3/msvc2022_64",
          "type": "STRING"
        },
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    }
  ]
}